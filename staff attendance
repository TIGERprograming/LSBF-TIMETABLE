async function sendEmailViaBackend(notif) {
  try {
    const res = await fetch(`${API_BASE}/api/notify/email`, {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(notif),
    });
    const data = await res.json();
    return data.success;
  } catch(e) {
    console.error('Email send failed:', e);
    return false;
  }
}

async function sendAllNotifications() {
  const btn = document.querySelector('.send-notif-btn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader ti-spin"></i> Sending...'; }

  let sent = 0;
  for (let i = 0; i < notifLog.length; i++) {
    if (notifSentSet.has(i)) continue;
    const ok = await sendEmailViaBackend(notifLog[i]);
    if (ok) { notifSentSet.add(i); sent++; }
  }

  showToast(`<i class="ti ti-mail"></i> ${sent} email${sent!==1?'s':''} sent via Gmail`);
  renderNotifications();
}

async function sendSingleEmail(i) {
  const ok = await sendEmailViaBackend(notifLog[i]);
  if (ok) { notifSentSet.add(i); showToast('<i class="ti ti-check"></i> Email sent to '+notifLog[i].studentEmail); renderNotifications(); }
