// ─────────────────────────────────────────────────────────────
//  UTILITY
// ─────────────────────────────────────────────────────────────
function todayKey() { return new Date().toISOString().slice(0,10); }
function fmtDate(key) {
  const [y,m,d]=key.split('-');
  return new Date(+y,+m-1,+d).toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
}
function tick() {
  const now=new Date();
  document.getElementById('live-date').textContent=
    now.toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short',year:'numeric'})+
    ' · '+now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
}
function leaveClass(t){return t==='Medical Leave'?'medical':t==='Emergency Leave'?'emergency':t==='Annual Leave'?'annual':'absent';}

function updateStats() {
  const p=staff.filter(s=>s.present).length,a=staff.filter(s=>!s.present).length,t=staff.length;
  ['s','a'].forEach(x=>{
    const pe=document.getElementById(x+'-present');const ae=document.getElementById(x+'-absent');const te=document.getElementById(x+'-total');
    if(pe)pe.textContent=p;if(ae)ae.textContent=a;if(te)te.textContent=t;
  });
}

function depts(){return[...new Set(staff.map(s=>s.dept))].sort();}
function fillDepts(){
  ['s-dept','a-dept'].forEach(id=>{
    const sel=document.getElementById(id);if(!sel)return;
    const cur=sel.value;while(sel.options.length>1)sel.remove(1);
    depts().forEach(d=>{const o=document.createElement('option');o.value=d;o.textContent=d;sel.appendChild(o);});
    sel.value=cur||'all';
  });
  const dsel=document.getElementById('ns-dept-sel');if(!dsel)return;
  while(dsel.options.length>1)dsel.remove(1);
  depts().forEach(d=>{const o=document.createElement('option');o.value=d;o.textContent=d;dsel.appendChild(o);});
}

function getFiltered(si,sti,di){
  const q=(document.getElementById(si)?.value||'').toLowerCase();
  const st=document.getElementById(sti)?.value||'all';
  const dp=document.getElementById(di)?.value||'all';
  return staff.filter(s=>{
    const nm=s.name.toLowerCase().includes(q)||s.dept.toLowerCase().includes(q)||s.subj.toLowerCase().includes(q);
    const sok=st==='all'||(st==='present'&&s.present)||(st==='absent'&&!s.present);
    const dok=dp==='all'||s.dept===dp;
    return nm&&sok&&dok;
  });
}

