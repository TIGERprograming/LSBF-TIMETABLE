<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LSBF Staff Attendance Portal</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --color-background-primary: #ffffff;
  --color-background-secondary: #f5f5f5;
  --color-background-tertiary: #efefef;
  --color-border-tertiary: #e0e0e0;
  --color-border-secondary: #d0d0d0;
  --color-text-primary: #1a1a1a;
  --color-text-secondary: #666;
  --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --border-radius-lg: 10px;
  --border-radius-md: 6px;
}
body { background: var(--color-background-tertiary); font-family: var(--font-sans); }
.portal { min-height: 100vh; }
.header { background: #1a1a1a; color: white; }
.header-inner { display: flex; align-items: center; gap: 20px; padding: 14px 24px; }
.lsbf-main { font-size: 32px; font-weight: 800; color: #c0272d; letter-spacing: -1px; font-family: Arial Black, Arial, sans-serif; }
.lsbf-college { font-size: 14px; color: #ccc; letter-spacing: 2px; margin-top: -2px; }
.lsbf-sub { font-size: 10px; color: #999; margin-top: 3px; border-top: 0.5px solid #555; padding-top: 3px; }
.lsbf-text { display: flex; flex-direction: column; line-height: 1; }
.header-divider { width: 1px; height: 48px; background: #444; margin: 0 8px; }
.header-portal-info h1 { font-size: 15px; font-weight: 500; color: white; }
.header-portal-info p { font-size: 11px; color: #999; margin-top: 3px; }
.header-right { display: flex; align-items: center; gap: 12px; margin-left: auto; flex-wrap: wrap; }
.header-date { font-size: 11px; color: #999; text-align: right; }
.admin-user-pill { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.08); border: 0.5px solid #444; border-radius: 30px; padding: 4px 12px 4px 5px; }
.admin-avatar { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; background: #c0272d; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: white; }
.admin-name { font-size: 12px; color: #ddd; }
.logout-btn { padding: 6px 14px; font-size: 12px; background: rgba(255,255,255,0.08); color: #ccc; border: 0.5px solid #555; border-radius: var(--border-radius-md); cursor: pointer; display: flex; align-items: center; gap: 5px; }
.logout-btn:hover { background: rgba(255,255,255,0.15); }
.nav-bar { background: #111; display: flex; border-top: 1px solid #333; }
.nav-btn { padding: 11px 22px; font-size: 13px; color: #aaa; cursor: pointer; border: none; background: none; border-bottom: 3px solid transparent; transition: all 0.15s; display: flex; align-items: center; gap: 7px; }
.nav-btn.active { color: white; border-bottom-color: #c0272d; background: rgba(255,255,255,0.04); }
.nav-btn:hover:not(.active) { background: rgba(255,255,255,0.03); color: #ddd; }
.content { padding: 20px 24px; }
.view { display: none; }
.view.active { display: block; }
.stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
.stat-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 14px 18px; }
.slabel { font-size: 11px; color: var(--color-text-secondary); margin-bottom: 6px; display: flex; align-items: center; gap: 6px; }
.svalue { font-size: 28px; font-weight: 500; }
.svalue.green { color: #2d7a2d; } .svalue.red { color: #a32d2d; } .svalue.blue { color: #185fa5; }
.dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
.dot.green { background: #639922; } .dot.red { background: #e24b4a; } .dot.blue { background: #378add; }
.search-bar { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
.search-bar input { flex: 1; min-width: 160px; padding: 8px 12px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; background: var(--color-background-primary); color: var(--color-text-primary); }
.fsel { padding: 8px 12px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; background: var(--color-background-primary); color: var(--color-text-primary); }
.staff-table { width: 100%; border-collapse: collapse; background: var(--color-background-primary); border-radius: var(--border-radius-lg); overflow: hidden; border: 0.5px solid var(--color-border-tertiary); table-layout: fixed; }
.staff-table th { background: var(--color-background-secondary); font-size: 11px; font-weight: 500; color: var(--color-text-secondary); padding: 10px 14px; text-align: left; border-bottom: 0.5px solid var(--color-border-tertiary); text-transform: uppercase; letter-spacing: 0.5px; }
.staff-table td { padding: 11px 14px; font-size: 13px; border-bottom: 0.5px solid var(--color-border-tertiary); color: var(--color-text-primary); vertical-align: middle; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.staff-table tr:last-child td { border-bottom: none; }
.staff-table tr:hover td { background: var(--color-background-secondary); }
.badge { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 500; }
.badge.present { background: #eaf3de; color: #3b6d11; }
.badge.absent { background: #fcebeb; color: #a32d2d; }
.badge.medical { background: #fff3e0; color: #b85c00; }
.badge.emergency { background: #fce4ec; color: #b71c3c; }
.badge.annual { background: #e3f2fd; color: #1565c0; }
.leave-reason { font-size: 11px; color: var(--color-text-secondary); margin-top: 3px; display: flex; align-items: center; gap: 4px; }
.toggle-btn { padding: 5px 14px; border-radius: var(--border-radius-md); font-size: 12px; cursor: pointer; border: 0.5px solid var(--color-border-secondary); background: var(--color-background-secondary); color: var(--color-text-primary); transition: all 0.15s; white-space: nowrap; }
.toggle-btn.mark-absent { border-color: #f0c4c4; color: #a32d2d; }
.toggle-btn.mark-present { border-color: #c0dd97; color: #3b6d11; }

/* ── Google Sign-In Screen ── */
.admin-lock { display: flex; align-items: center; justify-content: center; padding: 40px 0; }
.login-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 40px; width: 380px; text-align: center; }
.login-logo { display: flex; flex-direction: column; align-items: center; margin-bottom: 24px; }
.login-lsbf { font-size: 40px; font-weight: 800; color: #c0272d; font-family: Arial Black, Arial, sans-serif; line-height: 1; }
.login-college { font-size: 13px; color: var(--color-text-secondary); letter-spacing: 2px; }
.login-sub { font-size: 10px; color: var(--color-text-secondary); border-top: 0.5px solid var(--color-border-tertiary); padding-top: 6px; margin-top: 4px; }
.login-card h2 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
.login-card .sub { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 28px; line-height: 1.6; }
.google-btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 12px 16px; background: white; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; font-weight: 500; color: #333; cursor: pointer; transition: box-shadow 0.15s, background 0.15s; text-decoration: none; }
.google-btn:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.12); background: #fafafa; }
.google-logo { width: 20px; height: 20px; }
.auth-notice { margin-top: 16px; font-size: 11px; color: var(--color-text-secondary); line-height: 1.6; }
.auth-failed-msg { background: #fcebeb; border: 0.5px solid #f0c4c4; border-radius: var(--border-radius-md); padding: 10px 14px; font-size: 12px; color: #a32d2d; margin-bottom: 16px; display: none; }

/* ── Sub-tabs ── */
.sub-tabs { display: flex; gap: 0; margin-bottom: 20px; border-bottom: 0.5px solid var(--color-border-tertiary); flex-wrap: wrap; }
.sub-tab { padding: 9px 20px; font-size: 13px; color: var(--color-text-secondary); cursor: pointer; border: none; background: none; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; display: flex; align-items: center; gap: 7px; }
.sub-tab.active { color: #c0272d; border-bottom-color: #c0272d; font-weight: 500; }
.sub-tab:hover:not(.active) { color: var(--color-text-primary); }
.sub-panel { display: none; }
.sub-panel.active { display: block; }

/* ── Leave modal ── */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.modal-overlay.hidden { display: none; }
.modal { background: var(--color-background-primary); border-radius: var(--border-radius-lg); padding: 28px; width: 380px; box-shadow: 0 8px 40px rgba(0,0,0,0.18); }
.modal h3 { font-size: 15px; font-weight: 600; margin-bottom: 6px; display: flex; align-items: center; gap: 8px; }
.modal p { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 16px; }
.modal label { font-size: 12px; color: var(--color-text-secondary); display: block; margin-bottom: 5px; }
.modal select, .modal textarea { width: 100%; padding: 9px 12px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; background: var(--color-background-primary); color: var(--color-text-primary); margin-bottom: 14px; font-family: var(--font-sans); }
.modal textarea { resize: vertical; min-height: 70px; }
.modal-actions { display: flex; gap: 10px; margin-top: 4px; }
.modal-actions button { flex: 1; padding: 9px; border-radius: var(--border-radius-md); font-size: 13px; cursor: pointer; border: 0.5px solid var(--color-border-secondary); }
.btn-primary { background: #c0272d !important; color: white !important; border-color: #c0272d !important; font-weight: 500; }
.btn-primary:hover { background: #a01f24 !important; }
.btn-cancel { background: var(--color-background-secondary); color: var(--color-text-primary); }

/* ── Add staff ── */
.add-staff-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 28px; flex: 1; min-width: 280px; }
.add-staff-card h3 { font-size: 15px; font-weight: 500; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
.add-staff-card .desc { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 20px; padding-bottom: 14px; border-bottom: 0.5px solid var(--color-border-tertiary); }
.field-label { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 5px; display: block; }
.add-staff-card input, .add-staff-card select { width: 100%; margin-bottom: 12px; padding: 9px 12px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; background: var(--color-background-primary); color: var(--color-text-primary); }
.save-btn { width: 100%; padding: 10px; background: #c0272d; color: white; border: none; border-radius: var(--border-radius-md); font-size: 13px; cursor: pointer; font-weight: 500; }
.save-btn:hover { background: #a01f24; }
.staff-list-mini { border-top: 0.5px solid var(--color-border-tertiary); padding-top: 14px; margin-top: 16px; }
.staff-list-mini h4 { font-size: 12px; font-weight: 500; color: var(--color-text-secondary); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
.staff-item-mini { display: flex; align-items: center; justify-content: space-between; padding: 8px 10px; border-radius: var(--border-radius-md); border: 0.5px solid var(--color-border-tertiary); margin-bottom: 6px; background: var(--color-background-secondary); font-size: 12px; }
.staff-item-mini .sname { font-weight: 500; }
.staff-item-mini .sdept { color: var(--color-text-secondary); font-size: 11px; margin-top: 1px; }
.remove-staff-btn { background: none; border: none; color: #aaa; cursor: pointer; font-size: 15px; padding: 2px 4px; border-radius: 4px; }
.remove-staff-btn:hover { color: #a32d2d; background: #fcebeb; }

/* ── Settings ── */
.settings-wrap { display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap; }
.settings-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 28px; width: 360px; }
.settings-card h3 { font-size: 15px; font-weight: 500; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
.settings-card .desc { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 22px; padding-bottom: 16px; border-bottom: 0.5px solid var(--color-border-tertiary); }
.settings-card input { width: 100%; margin-bottom: 14px; padding: 9px 12px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; background: var(--color-background-primary); color: var(--color-text-primary); }
.pw-row { position: relative; margin-bottom: 14px; }
.pw-row input { margin-bottom: 0; padding-right: 38px; width: 100%; }
.pw-toggle { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--color-text-secondary); font-size: 16px; }
.info-box { background: var(--color-background-secondary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-md); padding: 14px 16px; font-size: 12px; color: var(--color-text-secondary); line-height: 1.8; }
.info-box strong { color: var(--color-text-primary); }
.error-msg { color: #a32d2d; font-size: 12px; margin-bottom: 10px; display: none; }
.success-msg { color: #3b6d11; font-size: 12px; margin-bottom: 10px; display: none; }

/* ── Notifications ── */
.students-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 20px 24px; margin-bottom: 16px; }
.students-card h3 { font-size: 14px; font-weight: 500; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.student-row { display: flex; align-items: flex-start; gap: 16px; padding: 12px 14px; background: var(--color-background-secondary); border-radius: var(--border-radius-md); margin-bottom: 8px; flex-wrap: wrap; }
.student-info strong { font-size: 13px; font-weight: 500; }
.student-info .smeta { font-size: 11px; color: var(--color-text-secondary); margin-top: 2px; }
.affected-badge { display: inline-flex; align-items: center; gap: 4px; background: #fff3e0; color: #b85c00; border: 0.5px solid #ffcc80; border-radius: 20px; font-size: 11px; font-weight: 500; padding: 2px 10px; }
.notif-log-item { padding: 14px 18px; border-bottom: 0.5px solid var(--color-border-tertiary); }
.notif-log-item:last-child { border-bottom: none; }
.notif-banner { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); overflow: hidden; }
.notif-section { margin-top: 24px; }
.notif-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
.notif-header h3 { font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 6px; }
.no-notif { text-align: center; padding: 32px; color: var(--color-text-secondary); font-size: 13px; }
.send-notif-btn { padding: 7px 16px; background: #1565c0; color: white; border: none; border-radius: var(--border-radius-md); font-size: 12px; cursor: pointer; font-weight: 500; display: flex; align-items: center; gap: 6px; }
.send-notif-btn:hover { background: #0d47a1; }
.send-notif-btn:disabled { background: #aaa; cursor: not-allowed; }
.btn-email { padding: 5px 12px; background: #e3f2fd; color: #1565c0; border: 0.5px solid #90caf9; border-radius: var(--border-radius-md); font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 5px; font-weight: 500; }
.btn-email:hover { background: #bbdefb; }
.notif-preview-box { background: #f8f9ff; border: 0.5px solid #dce4ff; border-radius: var(--border-radius-md); padding: 12px 16px; font-size: 12px; color: #555; line-height: 1.7; margin-top: 8px; }
.sent-badge { display: inline-flex; align-items: center; gap: 4px; background: #eaf3de; color: #3b6d11; border-radius: 20px; font-size: 11px; font-weight: 500; padding: 2px 10px; }

/* ── Reports ── */
.report-toolbar { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }
.snap-btn { padding: 8px 18px; background: #c0272d; color: white; border: none; border-radius: var(--border-radius-md); font-size: 13px; cursor: pointer; font-weight: 500; display: flex; align-items: center; gap: 6px; }
.snap-btn:hover { background: #a01f24; }
.dl-btn { padding: 8px 16px; background: var(--color-background-primary); color: var(--color-text-primary); border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; }
.dl-btn:hover { background: var(--color-background-secondary); }
.report-list { display: flex; flex-direction: column; gap: 12px; }
.report-card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); overflow: hidden; }
.report-header { display: flex; align-items: center; gap: 14px; padding: 14px 18px; cursor: pointer; user-select: none; flex-wrap: wrap; transition: background 0.15s; }
.report-header:hover { background: var(--color-background-secondary); }
.report-header.open { border-bottom: 0.5px solid var(--color-border-tertiary); }
.report-date-badge { background: #1a2e5e; color: white; font-size: 12px; font-weight: 500; padding: 4px 12px; border-radius: var(--border-radius-md); white-space: nowrap; }
.report-summary { display: flex; gap: 16px; flex: 1; flex-wrap: wrap; }
.rsm { font-size: 12px; color: var(--color-text-secondary); display: flex; align-items: center; gap: 5px; }
.rsm strong { color: var(--color-text-primary); font-weight: 500; }
.report-actions { display: flex; gap: 8px; margin-left: auto; }
.icon-btn { padding: 5px 10px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: var(--color-background-secondary); cursor: pointer; font-size: 13px; color: var(--color-text-secondary); display: flex; align-items: center; gap: 5px; white-space: nowrap; }
.icon-btn:hover { background: var(--color-background-tertiary); }
.icon-btn.danger:hover { border-color: #f0c4c4; color: #a32d2d; background: #fcebeb; }
.report-body { display: none; padding: 0 18px 14px; }
.report-body.open { display: block; }
.mini-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 12px; }
.mini-table th { font-size: 11px; font-weight: 500; color: var(--color-text-secondary); padding: 6px 10px; text-align: left; border-bottom: 0.5px solid var(--color-border-tertiary); background: var(--color-background-secondary); text-transform: uppercase; }
.mini-table td { padding: 7px 10px; border-bottom: 0.5px solid var(--color-border-tertiary); }
.mini-table tr:last-child td { border-bottom: none; }
.no-reports { text-align: center; padding: 40px; color: var(--color-text-secondary); font-size: 13px; }
.chevron { transition: transform 0.2s; font-size: 14px; color: var(--color-text-secondary); }
.chevron.open { transform: rotate(180deg); }
.report-search { padding: 8px 12px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 13px; background: var(--color-background-primary); color: var(--color-text-primary); width: 220px; }
.admin-badge-pill { display: inline-block; background: #c0272d; color: white; font-size: 10px; font-weight: 500; padding: 2px 8px; border-radius: 20px; margin-left: 8px; }
.saved-toast { position: fixed; bottom: 24px; right: 24px; background: #1a2e5e; color: white; padding: 10px 20px; border-radius: var(--border-radius-md); font-size: 13px; font-weight: 500; opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 2000; display: flex; align-items: center; gap: 8px; }
.saved-toast.show { opacity: 1; }
.strength-bar { height: 4px; border-radius: 4px; background: var(--color-background-secondary); margin-top: -10px; margin-bottom: 14px; overflow: hidden; }
.strength-fill { height: 100%; border-radius: 4px; transition: width 0.3s, background 0.3s; width: 0%; }
.strength-label { font-size: 11px; color: var(--color-text-secondary); margin-top: -10px; margin-bottom: 14px; }
.reason-sel { padding: 4px 8px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); font-size: 11px; background: var(--color-background-secondary); color: var(--color-text-primary); cursor: pointer; }
</style>
</head>
<body>
<div class="portal">
  <div class="header">
    <div class="header-inner">
      <div class="lsbf-text">
        <span class="lsbf-main">LSBF</span>
        <span class="lsbf-college">College</span>
        <span class="lsbf-sub">London School of Business &amp; Finance</span>
      </div>
      <div class="header-divider"></div>
      <div class="header-portal-info">
        <h1>Staff Attendance Portal</h1>
        <p>May 2026 Semester &nbsp;·&nbsp; Master Campus</p>
      </div>
      <div class="header-right">
        <div class="header-date" id="live-date"></div>
        <div id="admin-user-wrap" style="display:none;" class="admin-user-pill">
          <div id="admin-avatar" class="admin-avatar"></div>
          <span id="admin-name" class="admin-name"></span>
        </div>
        <button class="logout-btn" id="logout-btn" style="display:none;" onclick="logoutAdmin()"><i class="ti ti-logout"></i> Sign out</button>
      </div>
    </div>
    <div class="nav-bar">
      <button class="nav-btn active" onclick="switchView('student')"><i class="ti ti-users"></i> Student View</button>
      <button class="nav-btn" onclick="switchView('admin')"><i class="ti ti-lock"></i> Admin View <span id="admin-indicator"></span></button>
    </div>
  </div>

  <div class="content">
    <!-- STUDENT VIEW -->
    <div class="view active" id="view-student">
      <div class="stats-row">
        <div class="stat-card"><div class="slabel"><span class="dot green"></span> Present today</div><div class="svalue green" id="s-present">—</div></div>
        <div class="stat-card"><div class="slabel"><span class="dot red"></span> Absent today</div><div class="svalue red" id="s-absent">—</div></div>
