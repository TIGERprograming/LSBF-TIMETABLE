      ?`<span class="badge present"><span class="dot green" style="width:6px;height:6px;"></span>Present</span>`
      :`<div><span class="badge ${leaveClass(s.leaveType)}"><span class="dot red" style="width:6px;height:6px;"></span>Absent${s.leaveType?' · '+s.leaveType:''}</span>${s.leaveNote?`<div class="leave-reason"><i class="ti ti-note" style="font-size:11px;"></i>${s.leaveNote}</div>`:''}</div>`;
    tr.innerHTML=`<td style="font-weight:500;">${s.name}</td><td style="color:var(--color-text-secondary);font-size:12px;">${s.dept}</td><td style="color:var(--color-text-secondary);font-size:12px;">${s.subj}</td><td>${statusCell}</td>`;
    tb.appendChild(tr);
  });
}

// ─────────────────────────────────────────────────────────────
//  RENDER — ADMIN VIEW
// ─────────────────────────────────────────────────────────────
function renderAdmin(){
  const rows=getFiltered('a-search','a-status','a-dept');
  const tb=document.getElementById('a-tbody');tb.innerHTML='';
  if(!rows.length){tb.innerHTML='<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--color-text-secondary);">No staff found.</td></tr>';return;}
  rows.forEach(s=>{
    const idx=staff.indexOf(s);
    const tr=document.createElement('tr');
    const statusCell=s.present
      ?`<span class="badge present"><span class="dot green" style="width:6px;height:6px;"></span>Present</span>`
      :`<div><span class="badge ${leaveClass(s.leaveType)}"><span class="dot red" style="width:6px;height:6px;"></span>${s.leaveType||'Absent'}</span>${s.leaveNote?`<div class="leave-reason" style="white-space:normal;">${s.leaveNote}</div>`:''}<select class="reason-sel" style="margin-top:5px;" onchange="setLeaveType(${idx},this.value)"><option value="">Change reason…</option><option value="Medical Leave" ${s.leaveType==='Medical Leave'?'selected':''}>🏥 Medical Leave</option><option value="Emergency Leave" ${s.leaveType==='Emergency Leave'?'selected':''}>🚨 Emergency Leave</option><option value="Annual Leave" ${s.leaveType==='Annual Leave'?'selected':''}>🌴 Annual Leave</option></select></div>`;
    tr.innerHTML=`<td style="font-weight:500;">${s.name}</td><td style="color:var(--color-text-secondary);font-size:12px;">${s.dept}</td><td style="color:var(--color-text-secondary);font-size:12px;">${s.subj}</td><td>${statusCell}</td><td style="text-align:center;"><button class="toggle-btn ${s.present?'mark-absent':'mark-present'}" onclick="${s.present?'openLeaveModal('+idx+')':'markPresent('+idx+')'}">${s.present?'Mark absent':'Mark present'}</button></td>`;
    tb.appendChild(tr);
  });
}

function setLeaveType(idx,val){if(!val)return;staff[idx].leaveType=val;updateStats();renderStudent();renderAdmin();checkAndNotify(idx);showToast('<i class="ti ti-check"></i> Leave type set to '+val);}

// ─────────────────────────────────────────────────────────────
//  LEAVE MODAL
// ─────────────────────────────────────────────────────────────
function openLeaveModal(idx){pendingLeaveIdx=idx;document.getElementById('modal-staff-name').textContent=staff[idx].name;document.getElementById('modal-leave-type').value=staff[idx].leaveType||'Medical Leave';document.getElementById('modal-note').value=staff[idx].leaveNote||'';document.getElementById('leave-modal').classList.remove('hidden');}
function closeLeaveModal(){document.getElementById('leave-modal').classList.add('hidden');pendingLeaveIdx=null;}
function confirmLeave(){
  const idx=pendingLeaveIdx;if(idx===null)return;
  staff[idx].present=false;staff[idx].leaveType=document.getElementById('modal-leave-type').value;staff[idx].leaveNote=document.getElementById('modal-note').value.trim();
  closeLeaveModal();updateStats();renderStudent();renderAdmin();checkAndNotify(idx);
  showToast('<i class="ti ti-user-off"></i> '+staff[idx].name+' marked absent ('+staff[idx].leaveType+')');
}
function markPresent(idx){staff[idx].present=true;staff[idx].leaveType='';staff[idx].leaveNote='';updateStats();renderStudent();renderAdmin();showToast('<i class="ti ti-user-check"></i> '+staff[idx].name+' marked present');}

// ─────────────────────────────────────────────────────────────
//  NOTIFICATIONS
// ─────────────────────────────────────────────────────────────
function checkAndNotify(idx){
  const s=staff[idx];if(s.present)return;
  students.forEach(student=>{
    const affected=student.departments.some(d=>s.dept.toLowerCase().includes(d.toLowerCase()));
    if(!affected)return;
    const key=`${student.email}::${s.name}::${todayKey()}`;
    if(notifLog.find(n=>n._key===key))return; // deduplicate
    notifLog.push({_key:key,studentName:student.name,studentEmail:student.email,studentPhone:student.phone,staffName:s.name,dept:s.dept,leaveType:s.leaveType||'Absent',leaveNote:s.leaveNote||'',timestamp:new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}),programme:student.programme});
    updateNotifBadge();
  });
  renderNotifications();
}

function updateNotifBadge(){const b=document.getElementById('notif-count-badge');if(b)b.textContent=notifLog.length>0?notifLog.length:'';}

function renderNotifications(){
  const wrap=document.getElementById('notif-body');if(!wrap)return;
  const absentAffected=staff.filter(s=>!s.present&&students.some(st=>st.departments.some(d=>s.dept.toLowerCase().includes(d.toLowerCase()))));
  let html=`<div class="students-card"><h3><i class="ti ti-users"></i> Registered students for alerts</h3>`;
  students.forEach(st=>{
    const aff=staff.filter(s=>!s.present&&st.departments.some(d=>s.dept.toLowerCase().includes(d.toLowerCase())));
    html+=`<div class="student-row"><div class="student-info"><strong>${st.name}</strong><div class="smeta"><i class="ti ti-school" style="font-size:11px;"></i> ${st.programme} &nbsp;·&nbsp; <i class="ti ti-mail" style="font-size:11px;"></i> ${st.email} &nbsp;·&nbsp; <i class="ti ti-phone" style="font-size:11px;"></i> ${st.phone}</div>${aff.length?`<div style="margin-top:5px;display:flex;gap:5px;flex-wrap:wrap;">`+aff.map(s=>`<span class="affected-badge"><i class="ti ti-user-off" style="font-size:10px;"></i> ${s.name} (${s.leaveType||'Absent'})</span>`).join('')+`</div>`:`<div style="margin-top:5px;font-size:11px;color:#3b6d11;">✓ No affected lecturers today</div>`}</div></div>`;
  });
  html+=`</div><div class="notif-section"><div class="notif-header"><h3><i class="ti ti-bell-ringing"></i> Pending notifications</h3>${notifLog.length?`<button class="send-notif-btn" onclick="sendAllNotifications()"><i class="ti ti-send"></i> Send all via Gmail</button>`:''}</div><div class="notif-banner">`;
  if(!notifLog.length){html+=`<div class="no-notif"><i class="ti ti-bell-off" style="font-size:28px;display:block;margin-bottom:8px;"></i>No notifications triggered yet.<br><span style="font-size:12px;">Mark a Computer Science lecturer absent to generate an alert for Ahrnan.</span></div>`;}
  else{
    notifLog.slice().reverse().forEach((log,ri)=>{
      const i=notifLog.length-1-ri;
      const sent=notifSentSet.has(i);
      html+=`<div class="notif-log-item"><div><div style="font-size:13px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;"><strong>${log.studentName}</strong> — <strong>${log.staffName}</strong> absent (${log.leaveType}) ${sent?'<span class="sent-badge"><i class="ti ti-check" style="font-size:10px;"></i> Sent</span>':''}</div><div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px;"><i class="ti ti-clock" style="font-size:10px;"></i> ${log.timestamp} · ${log.programme}</div>${!sent?`<div style="margin-top:8px;"><button class="btn-email" onclick="sendSingleEmail(${i})"><i class="ti ti-mail"></i> Send email to ${log.studentEmail}</button></div>`:''}
      <div class="notif-preview-box" style="margin-top:8px;"><strong>Email preview:</strong><br>To: ${log.studentEmail}<br>Subject: [LSBF] Class Alert – ${log.staffName} is Absent Today<br><br>Dear ${log.studentName},<br>This is an automated alert. <strong>${log.staffName}</strong> (${log.dept}) is absent today due to <strong>${log.leaveType}</strong>.${log.leaveNote?'<br>Note: '+log.leaveNote:''}<br>Please contact your coordinator for replacement class info.</div></div></div>`;
    });
  }
  html+=`</div></div>`;
  wrap.innerHTML=html;
}

// ─────────────────────────────────────────────────────────────
//  ADD STAFF
// ─────────────────────────────────────────────────────────────
function addStaff(){
  const name=document.getElementById('ns-name').value.trim();
  const deptSel=document.getElementById('ns-dept-sel').value;
  const deptNew=document.getElementById('ns-dept-new').value.trim();
  const subj=document.getElementById('ns-subj').value.trim();
  const dept=deptNew||deptSel;
  const err=document.getElementById('ns-error');const suc=document.getElementById('ns-success');
  err.style.display='none';suc.style.display='none';
  if(!name){err.textContent='Please enter the staff name.';err.style.display='block';return;}
  if(!dept){err.textContent='Please select or enter a department.';err.style.display='block';return;}
  if(!subj){err.textContent='Please enter at least one subject.';err.style.display='block';return;}
  if(staff.some(s=>s.name.toLowerCase()===name.toLowerCase())){err.textContent='A staff member with this name already exists.';err.style.display='block';return;}
  const nm={name,dept,subj,present:true,leaveType:'',leaveNote:''};
  staff.push(nm);newlyAddedStaff.push(nm);
  document.getElementById('ns-name').value='';document.getElementById('ns-dept-sel').value='';document.getElementById('ns-dept-new').value='';document.getElementById('ns-subj').value='';
  suc.textContent='✓ '+name+' added successfully!';suc.style.display='block';
  fillDepts();updateStats();renderStudent();renderAdmin();renderNewStaffList();
  showToast('<i class="ti ti-user-plus"></i> '+name+' added');
}
function removeNewStaff(name){
  const idx=staff.findIndex(s=>s.name===name);if(idx>-1)staff.splice(idx,1);
  const ni=newlyAddedStaff.findIndex(s=>s.name===name);if(ni>-1)newlyAddedStaff.splice(ni,1);
  fillDepts();updateStats();renderStudent();renderAdmin();renderNewStaffList();
}
function renderNewStaffList(){
  const wrap=document.getElementById('new-staff-list');if(!wrap)return;
  if(!newlyAddedStaff.length){wrap.innerHTML='<p style="font-size:12px;color:var(--color-text-secondary);">None yet.</p>';return;}
  wrap.innerHTML=newlyAddedStaff.map(s=>`<div class="staff-item-mini"><div><div class="sname">${s.name}</div><div class="sdept">${s.dept} · ${s.subj}</div></div><button class="remove-staff-btn" onclick="removeNewStaff('${s.name.replace(/'/g,"\\'")}')"><i class="ti ti-x"></i></button></div>`).join('');
}

// ─────────────────────────────────────────────────────────────
//  REPORTS
// ─────────────────────────────────────────────────────────────
function saveReport(){
  const key=todayKey();const now=new Date();
  const savedAt=now.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const report={date:fmtDate(key),key,savedAt,present:staff.filter(s=>s.present).length,absent:staff.filter(s=>!s.present).length,total:staff.length,records:staff.map(s=>({name:s.name,dept:s.dept,subj:s.subj,status:s.present?'Present':'Absent',leaveType:s.leaveType||'',leaveNote:s.leaveNote||''}))};
  reports[key]=report;
  saveReportToBackend(key,report);
  updateReportBadge();showToast('<i class="ti ti-check"></i> Report saved for '+fmtDate(key));renderReports();
}
function updateReportBadge(){const n=Object.keys(reports).length;const b=document.getElementById('report-count-badge');if(b)b.textContent=n>0?n:'';}
function getFilteredReports(){
  const q=(document.getElementById('rpt-search')?.value||'').toLowerCase();
  const f=document.getElementById('rpt-filter')?.value||'all';
  const now=new Date();const weekStart=new Date(now);weekStart.setDate(now.getDate()-now.getDay());
  return Object.keys(reports).sort().reverse().filter(key=>{
    const r=reports[key];
    const matchQ=!q||key.includes(q)||r.date.toLowerCase().includes(q)||r.records.some(x=>x.name.toLowerCase().includes(q)||x.dept.toLowerCase().includes(q));
    const d=new Date(key);
    const matchF=f==='all'||(f==='thisweek'&&d>=weekStart)||(f==='thismonth'&&d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear());
    return matchQ&&matchF;
  });
}
function renderReports(){
  const keys=getFilteredReports();const list=document.getElementById('report-list');if(!list)return;
  if(!keys.length){list.innerHTML='<div class="no-reports"><i class="ti ti-archive" style="font-size:32px;display:block;margin-bottom:10px;"></i>No reports filed yet.<br><span style="font-size:12px;">Go to Attendance and click <strong>Save today\'s report</strong>.</span></div>';return;}
  list.innerHTML='';
  keys.forEach(key=>{
    const r=reports[key];const pct=Math.round((r.present/r.total)*100);
    const card=document.createElement('div');card.className='report-card';
    card.innerHTML=`<div class="report-header" onclick="toggleReport('${key}',this)"><span class="report-date-badge"><i class="ti ti-calendar"></i> ${r.date}</span><div class="report-summary"><span class="rsm"><span class="dot green" style="width:7px;height:7px;"></span> Present: <strong>${r.present}</strong></span><span class="rsm"><span class="dot red" style="width:7px;height:7px;"></span> Absent: <strong>${r.absent}</strong></span><span class="rsm"><i class="ti ti-percent"></i> Rate: <strong>${pct}%</strong></span><span class="rsm" style="font-size:11px;">Saved at ${r.savedAt}</span></div><div class="report-actions" onclick="event.stopPropagation()"><button class="icon-btn" onclick="exportCSV('${key}')"><i class="ti ti-file-spreadsheet"></i> CSV</button><button class="icon-btn" onclick="exportJSON('${key}')"><i class="ti ti-file-code"></i> JSON</button><button class="icon-btn danger" onclick="deleteReport('${key}')"><i class="ti ti-trash"></i></button></div><i class="ti ti-chevron-down chevron" id="chev-${key}"></i></div><div class="report-body" id="body-${key}"><table class="mini-table"><thead><tr><th>Name</th><th>Dept</th><th>Status</th><th>Leave Type</th></tr></thead><tbody>${r.records.map(x=>`<tr><td style="font-weight:500;">${x.name}</td><td style="color:var(--color-text-secondary);">${x.dept}</td><td><span class="badge ${x.status==='Present'?'present':leaveClass(x.leaveType)}">${x.status}</span></td><td style="font-size:11px;color:var(--color-text-secondary);">${x.leaveType||'—'}</td></tr>`).join('')}</tbody></table></div>`;
    list.appendChild(card);
  });
}
function toggleReport(key,hdr){const body=document.getElementById('body-'+key);const chev=document.getElementById('chev-'+key);const open=body.classList.toggle('open');hdr.classList.toggle('open',open);chev.classList.toggle('open',open);}
function deleteReport(key){if(!confirm('Delete the report for '+reports[key].date+'?'))return;delete reports[key];deleteReportFromBackend(key);updateReportBadge();renderReports();showToast('<i class="ti ti-trash"></i> Report deleted');}
function exportCSV(key){const r=reports[key];const rows=[['Date','Saved At','Name','Dept','Subjects','Status','Leave Type','Note'],...r.records.map(x=>[r.date,r.savedAt,x.name,x.dept,x.subj,x.status,x.leaveType||'',x.leaveNote||''])];download('LSBF_Attendance_'+key+'.csv','text/csv',rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n'));}
function exportJSON(key){download('LSBF_Attendance_'+key+'.json','application/json',JSON.stringify(reports[key],null,2));}
function exportAllCSV(){const keys=Object.keys(reports).sort();if(!keys.length){showToast('<i class="ti ti-alert-circle"></i> No reports');return;}const rows=[['Date','Saved At','Name','Dept','Subjects','Status','Leave Type','Note']];keys.forEach(k=>{const r=reports[k];r.records.forEach(x=>rows.push([r.date,r.savedAt,x.name,x.dept,x.subj,x.status,x.leaveType||'',x.leaveNote||'']));rows.push([]);});download('LSBF_Attendance_All.csv','text/csv',rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n'));}
function exportAllJSON(){if(!Object.keys(reports).length){showToast('<i class="ti ti-alert-circle"></i> No reports');return;}download('LSBF_Attendance_All.json','application/json',JSON.stringify(reports,null,2));}
function download(filename,mime,content){const a=document.createElement('a');a.href='data:'+mime+';charset=utf-8,'+encodeURIComponent(content);a.download=filename;document.body.appendChild(a);a.click();document.body.removeChild(a);showToast('<i class="ti ti-download"></i> Downloaded '+filename);}

// ─────────────────────────────────────────────────────────────
//  NAVIGATION
// ─────────────────────────────────────────────────────────────
function switchView(v){document.querySelectorAll('.view').forEach(e=>e.classList.remove('active'));document.querySelectorAll('.nav-btn').forEach(e=>e.classList.remove('active'));document.getElementById('view-'+v).classList.add('active');document.querySelectorAll('.nav-btn')[v==='student'?0:1].classList.add('active');}
function switchSub(s){document.querySelectorAll('.sub-panel').forEach(e=>e.classList.remove('active'));document.querySelectorAll('.sub-tab').forEach(e=>e.classList.remove('active'));document.getElementById('sub-'+s).classList.add('active');const idx={attendance:0,notifications:1,staff:2,reports:3,settings:4}[s];document.querySelectorAll('.sub-tab')[idx].classList.add('active');}
function toggleVis(id,btn){const inp=document.getElementById(id);const show=inp.type==='password';inp.type=show?'text':'password';btn.innerHTML=show?'<i class="ti ti-eye-off"></i>':'<i class="ti ti-eye"></i>';}

let toastTimer;
function showToast(msg){const t=document.getElementById('toast');t.innerHTML=msg;t.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),3200);}

fillDepts(); updateStats(); renderStudent();
</script>
</body>
</html>
